{
  "name": "hpm",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "android-start": "expo start --android",
    "ios-start": "expo start --ios",
    "android-release": "expo run:android --variant release",
    "android-clean": "cd android && ./gradlew clean",
    "android-assemble": "cd android && ./gradlew assembleRelease",
    "android-bundle": "cd android && ./gradlew bundleRelease && echo 'AAB file generated at: android/app/build/outputs/bundle/release/app-release.aab'",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.4",
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/slider": "4.5.6",
    "@react-navigation/bottom-tabs": "^7.4.2",
    "@react-navigation/drawer": "^7.5.3",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/stack": "^7.4.2",
    "expo": "~53.0.17",
    "expo-audio": "~0.4.8",
    "expo-constants": "~17.1.7",
    "expo-device": "~7.1.4",
    "expo-notifications": "~0.31.4",
    "expo-status-bar": "~2.2.3",
    "expo-updates": "~0.28.17",
    "expo-video": "~2.2.2",
    "expo-web-browser": "~14.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-google-mobile-ads": "^15.4.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-reanimated-carousel": "^4.0.2",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-track-player": "^4.1.2",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5",
    "react-native-youtube-iframe": "^2.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/cli": "^0.24.20",
    "@types/react": "~19.0.10",
    "eas-cli": "^16.15.0",
    "eslint": "^9.0.0",
